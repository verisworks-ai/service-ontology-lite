{
  "routes": [
    {
      "path": "/",
      "auth": "public",
      "handler": "app/page.tsx",
      "methods": ["GET"],
      "entities": [],
      "external_services": []
    },
    {
      "path": "/dashboard",
      "auth": "required",
      "handler": "app/dashboard/page.tsx",
      "methods": ["GET"],
      "entities": ["User"],
      "external_services": []
    },
    {
      "path": "/api/public",
      "auth": "public",
      "handler": "app/api/public/route.ts",
      "methods": ["GET"],
      "entities": [],
      "external_services": ["Supabase"]
    },
    {
      "path": "/api/admin",
      "auth": "admin",
      "handler": "app/api/admin/route.ts",
      "methods": ["POST"],
      "entities": ["User"],
      "external_services": ["Discord"]
    },
    {
      "path": "/api/cron",
      "auth": "cron",
      "handler": "app/api/cron/route.ts",
      "methods": ["GET"],
      "entities": [],
      "external_services": []
    }
  ],
  "entities": [
    {
      "name": "User",
      "storage": "database:users",
      "fields": ["id", "email"],
      "exposed_at": ["/dashboard", "/api/admin"]
    }
  ],
  "external_services": [
    {
      "name": "Discord",
      "type": "notification",
      "env": ["DISCORD_WEBHOOK_URL"],
      "used_by": ["app/api/admin/route.ts"]
    },
    {
      "name": "Supabase",
      "type": "database",
      "env": ["SUPABASE_URL"],
      "used_by": ["app/api/public/route.ts"]
    }
  ],
  "jobs": [
    {
      "name": "cron-healthcheck",
      "schedule": "*/10 * * * *",
      "handler": "app/api/cron/route.ts",
      "auth": "cron"
    }
  ],
  "agent_os": {
    "projects": [
      {"id": "service-ontology-lite", "name": "service-ontology-lite sample"}
    ],
    "agents": [
      {"id": "implementation-agent", "role": "implementation"},
      {"id": "research-agent", "role": "research"}
    ],
    "surfaces": [
      {"id": "local-sample-app", "type": "local_repo", "project_context_id": "service-ontology-lite"}
    ],
    "tasks": [
      {
        "id": "agent-os-registry-poc",
        "project_context_id": "service-ontology-lite",
        "owner_agent": "implementation-agent",
        "surface_id": "local-sample-app",
        "skills": ["source-first-project-development", "test-driven-development"]
      }
    ],
    "skills": [
      {"id": "source-first-project-development"},
      {"id": "test-driven-development"}
    ],
    "hooks": [
      {"id": "on_task_complete", "triggers": ["evidence_capture_loop"]}
    ],
    "loops": [
      {"id": "evidence_capture_loop", "pass_condition": "verified_output_recorded"}
    ],
    "plugins": [
      {"id": "service-ontology-lite"}
    ],
    "artifacts": [
      {"id": "pytest-agent-os-registry", "type": "test_output", "project_context_id": "service-ontology-lite"}
    ],
    "memories": [
      {"id": "sample/service-ontology-lite", "namespace": "project", "project_context_id": "service-ontology-lite"}
    ],
    "relations": [
      {"source": "agent-os-registry-poc", "relation": "produces", "target": "pytest-agent-os-registry"},
      {"source": "pytest-agent-os-registry", "relation": "updates", "target": "sample/service-ontology-lite"}
    ]
  }
}
